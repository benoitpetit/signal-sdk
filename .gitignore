# Ignore node modules
node_modules/

# Ignore TypeScript build output
dist/
build/
out/
/bin/
/lib/
/man/

# Ignore TypeScript cache
*.tsbuildinfo

# Ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore environment files
.env
.env.*

# Ignore IDE/editor folders
.vscode/
.idea/

# Ignore OS files
.DS_Store

# Ignore test coverage
coverage/

# Ignore declaration files (if not using outDir)
*.d.ts

# ignore signal-cli binaries and JVM artifacts downloaded at install time
bin/signal-cli
bin/signal-cli.bat

# Allow Windows test script
!test-windows.bat

# log files
logs/
*.log

# Ignore npm package files
*.tgz

# Ignore todo lists
todo.md
